# Copy this file to .env.local and fill in real values.

# Supabase — Settings → API in your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — resend.com → API Keys
RESEND_API_KEY=re_xxx
# Verified sending address (e.g. "BBM Leave <leave@blackbird.marketing>")
RESEND_FROM="BBM Leave <leave@blackbird.marketing>"

# Public site URL — used in email links. Update on Vercel after deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
